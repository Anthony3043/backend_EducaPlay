generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id          String   @id @default(uuid())
  nome        String
  email       String   @unique
  senha       String
  papel       String
  instituicao String?
  cargo       String?
  foto        String?
  resetToken     String?
  resetTokenExp  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  disponibilidades Disponibilidade[]
  notificacoes     Notificacao[]
  aulas            Aula[]             @relation("AulaProfessor")
  bloqueios        BloqueioHorario[]  @relation("BloqueiosProfessor")
}

model Professor {
  id        String   @id @default(uuid())
  nome      String
  materias  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  disponibilidades Disponibilidade[]
}

model Sala {
  id         String   @id @default(uuid())
  nome       String
  turma      String?
  capacidade String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  aulas Aula[]
}

model Cronograma {
  id        String   @id @default(uuid())
  turno     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  aulas Aula[]
}

model Aula {
  id           String     @id @default(uuid())
  timeStart    String
  timeEnd      String
  subject      String
  isInterval   Boolean    @default(false)
  cronogramaId String
  professorId  String?
  salaId       String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  cronograma Cronograma @relation(fields: [cronogramaId], references: [id], onDelete: Cascade)
  professor  Usuario?   @relation("AulaProfessor", fields: [professorId], references: [id])
  sala       Sala?      @relation(fields: [salaId], references: [id])
}

model Disponibilidade {
  id          String    @id @default(uuid())
  diaSemana   String
  turno       String
  professorId String
  usuarioId   String?
  createdAt   DateTime  @default(now())

  professor Professor @relation(fields: [professorId], references: [id], onDelete: Cascade)
  usuario   Usuario?  @relation(fields: [usuarioId], references: [id])
}

model BloqueioHorario {
  id          String   @id @default(uuid())
  professorId String
  timeStart   String
  timeEnd     String
  descricao   String?
  createdAt   DateTime @default(now())

  professor Usuario @relation("BloqueiosProfessor", fields: [professorId], references: [id], onDelete: Cascade)
}

model Notificacao {
  id        String   @id @default(uuid())
  titulo    String
  mensagem  String
  icon      String   @default("🔔")
  lida      Boolean  @default(false)
  usuarioId String
  createdAt DateTime @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
}
