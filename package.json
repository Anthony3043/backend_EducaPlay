{
  "name": "backend-educaplay",
  "version": "1.0.0",
  "description": "Backend da aplicação EducaPlay",
  "main": "server.js",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "npx prisma@5.22.0 db push && node server.js",
    "build": "npx prisma@5.22.0 generate",
    "postinstall": "npx prisma@5.22.0 generate",
    "db:migrate": "npx prisma@5.22.0 migrate dev --name init",
    "db:studio": "npx prisma@5.22.0 studio",
    "db:seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^8.0.7",
    "resend": "^6.12.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.7",
    "prisma": "^5.22.0"
  }
}
